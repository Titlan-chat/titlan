<!--
  Debug overlay: points debug builds at the debug-only network security config
  (the CI test-relay trust anchor). Merged only into debug builds; the release
  manifest has no networkSecurityConfig attribute at all, so release traffic
  stays on the platform default (TLS, no test anchors). See
  src/debug/res/xml/network_security_config.xml and scripts/check-invariants.sh.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application
        android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
